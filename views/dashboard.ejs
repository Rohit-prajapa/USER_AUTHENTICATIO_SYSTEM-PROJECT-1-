<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">

    <meta
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    >

    <title>Dashboard</title>

    <link
        rel="stylesheet"
        href="/css/style.css"
    >

</head>

<body>

<div class="container">

    <div class="card">

        <h1>
            Welcome <%= user.name %> 🎉
        </h1>

        <p>
            You are successfully logged in.
        </p>

        <p>
            <strong>Email:</strong>
            <%= user.email %>
        </p>

        <a href="/logout">
            <button>
                Logout
            </button>
        </a>

    </div>

</div>

</body>

</html>